{
    "name": "dotartisan/installer",
    "description": "The installer package for dotartisan.",
    "keywords": [
        "dotartisan",
        "installer"
    ],
    "homepage": "https://github.com/dotartisan/installer",
    "license": "The Unlicense",
    "type": "library",
    "authors": [
        {
            "name": "Abbas Arif",
            "email": "abbasarif@acexlogics.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "akaunting/laravel-setting": "^1.2",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "zanysoft/laravel-zip": "^2.0 || ^3.0",
        "jackiedo/dotenv-editor": "^1.0 || ^2.0",
        "igaster/laravel-theme": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0",
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Dotartisan\\Installer\\": "src"
        },
        "files": [
            "src/Helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Dotartisan\\Installer\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "post-autoload-dump": [
            "@php artisan dotartisan:install --ansi"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dotartisan\\Installer\\InstallerServiceProvider"
            ],
            "aliases": {
                "Installer": "Dotartisan\\Installer\\InstallerFacade"
            }
        }
    }
}
